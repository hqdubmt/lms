{
  "appId": "vn.masterlms.app",
  "appName": "MasterLMS",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": false
  },
  "plugins": {
    "Preferences": {
      "group": "MasterLMSPrefs"
    },
    "App": {}
  }
}
