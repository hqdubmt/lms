generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  username         String?          @unique
  passwordHash     String?
  name             String
  avatarUrl        String?
  bio              String?
  role             Role             @default(STUDENT)
  isVerified       Boolean          @default(false)
  isActive         Boolean          @default(true)
  twoFASecret      String?
  twoFAEnabled     Boolean          @default(false)
  googleId         String?          @unique
  githubId         String?          @unique
  telegramId       String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  certificates        Certificate[]
  classesCreated      Class[]              @relation("ClassCreator")
  classMemberships    ClassMember[]
  coursesCreated      Course[]             @relation("InstructorCourses")
  enrollments         Enrollment[]
  progress            LessonProgress[]
  sessionsCreated     LiveSession[]        @relation("SessionCreator")
  notifications       Notification[]
  payments            Payment[]
  refreshTokens       RefreshToken[]
  reviews             Review[]
  subscription        Subscription?
  todoItems           TodoItem[]
  vocabSetsCreated    VocabSet[]           @relation("VocabSetCreator")
  vocabProgresses     VocabProgress[]      @relation("VocabProgressUser")
  vocabItemProgresses VocabItemProgress[]  @relation("VocabItemProgressUser")
  exercisesCreated    LangExercise[]       @relation("ExerciseCreator")
  exerciseAttempts    ExerciseAttempt[]    @relation("ExerciseAttemptUser")
  langStats           LangUserStats?       @relation("LangUserStatsUser")
  mathTopicsCreated   MathTopic[]          @relation("MathTopicCreator")
  mathExercisesCreated MathExercise[]      @relation("MathExerciseCreator")
  mathAttempts        MathAttempt[]        @relation("MathAttemptUser")
  conceptProgresses   ConceptProgress[]    @relation("ConceptProgressUser")
  mathStats           MathUserStats?       @relation("MathUserStatsUser")
  mathDocuments       MathDocument[]       @relation("MathDocumentCreator")
  vietDocuments       VietDocument[]       @relation("VietDocumentCreator")
  vietSetsCreated     VietSet[]            @relation("VietSetCreator")
  vietItemProgresses  VietItemProgress[]   @relation("VietItemProgressUser")
  vietExercisesCreated VietExercise[]      @relation("VietExerciseCreator")
  vietAttempts        VietAttempt[]        @relation("VietAttemptUser")
  vietStats           VietUserStats?       @relation("VietUserStatsUser")
  mediaUploads        Media[]              @relation("MediaUploader")
  announcements       Announcement[]       @relation("AnnouncementAuthor")
  announcementReads   AnnouncementRead[]   @relation("AnnouncementReadUser")
  forumPosts          ForumPost[]          @relation("ForumPostAuthor")
  forumReplies        ForumReply[]         @relation("ForumReplyAuthor")
  forumLikes          ForumLike[]          @relation("ForumLikeUser")
  quizSets            QuizSet[]            @relation("QuizSetAuthor")
  quizAttempts        QuizAttempt[]        @relation("QuizAttemptUser")
  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  iconUrl     String?
  parentId    String?
  createdAt   DateTime   @default(now())
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  courses     Course[]
}

model Course {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  description   String?
  thumbnailUrl  String?
  previewUrl    String?
  instructorId  String
  categoryId    String?
  level         CourseLevel   @default(BEGINNER)
  status        CourseStatus  @default(DRAFT)
  price         Decimal       @default(0) @db.Decimal(10, 2)
  discountPrice Decimal?      @db.Decimal(10, 2)
  language      String        @default("vi")
  tags          String[]
  requirements  String[]
  objectives    String[]
  totalDuration Int           @default(0)
  totalLessons  Int           @default(0)
  totalStudents Int           @default(0)
  avgRating     Float         @default(0)
  totalReviews  Int           @default(0)
  isFree        Boolean       @default(false)
  isFeatured    Boolean       @default(false)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  certificates  Certificate[]
  category      Category?      @relation(fields: [categoryId], references: [id])
  instructor    User           @relation("InstructorCourses", fields: [instructorId], references: [id])
  enrollments   Enrollment[]
  liveSessions  LiveSession[]
  payments      Payment[]
  reviews       Review[]
  sections      Section[]
  vocabSets     VocabSet[]
  langExercises LangExercise[]
  mathTopics    MathTopic[]
  mathExercises MathExercise[]
  vietSets      VietSet[]
  vietExercises VietExercise[]
  mediaFiles    Media[]        @relation("MediaCourse")
  announcements Announcement[] @relation("AnnouncementCourse")
  classCourses  ClassCourse[]
  modules       CourseModule[]

  @@index([instructorId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([status, publishedAt])
}

model Section {
  id        String   @id @default(uuid())
  title     String
  order     Int
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lesson {
  id            String           @id @default(uuid())
  title         String
  slug          String
  description   String?
  type          LessonType       @default(VIDEO)
  order         Int
  sectionId     String
  videoKey      String?
  videoUrl      String?
  videoDuration Int?
  videoHlsKey   String?
  textContent   String?
  isFree        Boolean          @default(false)
  isPublished   Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  attachments    Attachment[]
  section        Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress       LessonProgress[]
  quizzes        Quiz[]
  lessonModules  LessonModule[]

  @@index([sectionId])
}

model Attachment {
  id        String   @id @default(uuid())
  name      String
  fileKey   String
  fileSize  Int
  mimeType  String
  lessonId  String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Quiz {
  id          String   @id @default(uuid())
  question    String
  options     String[]
  answer      Int
  explanation String?
  lessonId    String
  order       Int
  createdAt   DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  completedAt DateTime?
  enrolledAt  DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model LessonProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  isCompleted  Boolean   @default(false)
  watchTime    Int       @default(0)
  lastPosition Int       @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  courseId       String
  certificateKey String
  issuedAt       DateTime @default(now())
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  courseId    String?
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("VND")
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  txnRef      String?       @unique
  gatewayData Json?
  metadata    Json?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String             @unique
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  autoRenew Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model TodoItem {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  priority    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClassCourse {
  id        String   @id @default(uuid())
  classId   String
  courseId  String
  addedAt   DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([classId, courseId])
  @@index([classId])
  @@index([courseId])
}

model Class {
  id           String        @id @default(uuid())
  name         String
  description  String?
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  creator      User          @relation("ClassCreator", fields: [createdBy], references: [id])
  members      ClassMember[]
  liveSessions LiveSession[]
  courses      ClassCourse[]
  mediaFiles   Media[]        @relation("MediaClass")
  announcements Announcement[] @relation("AnnouncementClass")
  modules      ClassModule[]

  @@index([createdBy])
}

model ClassMember {
  id       String   @id @default(uuid())
  classId  String
  userId   String
  joinedAt DateTime @default(now())
  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
}

model LiveSession {
  id          String            @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  meetLink    String
  courseId    String?
  classId     String?
  createdBy   String
  status      LiveSessionStatus @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  class       Class?            @relation(fields: [classId], references: [id])
  course      Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  creator     User              @relation("SessionCreator", fields: [createdBy], references: [id])

  @@index([status])
  @@index([startTime])
  @@index([courseId])
  @@index([classId])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
  LIVE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  VNPAY
  MOMO
  ZALOPAY
  STRIPE
  PAYPAL
  CRYPTO
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

// ─── Language Learning Module ──────────────────────────────────────────────────

model VocabSet {
  id          String          @id @default(uuid())
  title       String
  description String?
  language    String          // "en", "ja", "ko", "fr", "zh", etc.
  targetLang  String          @default("vi")
  level       String          @default("A1")
  coverUrl    String?
  videoUrl    String?
  isPublic    Boolean         @default(true)
  createdBy   String
  courseId    String?
  parentId    String?
  items       VocabItem[]
  progresses  VocabProgress[]
  creator     User            @relation("VocabSetCreator", fields: [createdBy], references: [id])
  course      Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  parent      VocabSet?       @relation("VocabSetTree", fields: [parentId], references: [id])
  children    VocabSet[]      @relation("VocabSetTree")
  exercises   LangExercise[]  @relation("VocabSetExercises")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdBy])
  @@index([language])
  @@index([parentId])
}

model VocabItem {
  id           String              @id @default(uuid())
  setId        String
  word         String
  translation  String
  pronunciation String?
  audioUrl     String?
  imageUrl     String?
  example      String?
  exampleTrans String?
  notes        String?
  order        Int                 @default(0)
  set          VocabSet            @relation(fields: [setId], references: [id], onDelete: Cascade)
  progresses   VocabItemProgress[]
  createdAt    DateTime            @default(now())

  @@index([setId])
}

model VocabProgress {
  id          String    @id @default(uuid())
  userId      String
  setId       String
  wordsLearned Int      @default(0)
  lastStudied DateTime  @default(now())
  user        User      @relation("VocabProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  set         VocabSet  @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId])
  @@index([userId])
}

model VocabItemProgress {
  id          String    @id @default(uuid())
  userId      String
  itemId      String
  interval    Int       @default(1)
  easeFactor  Float     @default(2.5)
  repetitions Int       @default(0)
  nextReview  DateTime  @default(now())
  lastReview  DateTime?
  isLearned   Boolean   @default(false)
  user        User      @relation("VocabItemProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  item        VocabItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, nextReview])
  @@index([userId, isLearned])
}

model LangExercise {
  id          String              @id @default(uuid())
  title       String
  description String?
  type        LangExerciseType
  language    String
  level       String              @default("A1")
  timeLimit   Int?
  isPublic    Boolean             @default(true)
  createdBy   String
  courseId    String?
  vocabSetId  String?
  questions   ExerciseQuestion[]
  attempts    ExerciseAttempt[]
  creator     User                @relation("ExerciseCreator", fields: [createdBy], references: [id])
  course      Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  vocabSet    VocabSet?           @relation("VocabSetExercises", fields: [vocabSetId], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([createdBy])
  @@index([language, type])
  @@index([vocabSetId])
}

model ExerciseQuestion {
  id          String       @id @default(uuid())
  exerciseId  String
  content     String
  audioUrl    String?
  imageUrl    String?
  options     Json?
  answer      Json
  explanation String?
  order       Int          @default(0)
  points      Int          @default(1)
  exercise    LangExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model ExerciseAttempt {
  id          String       @id @default(uuid())
  userId      String
  exerciseId  String
  answers     Json
  score       Float
  timeTaken   Int?
  xpEarned    Int          @default(0)
  completedAt DateTime     @default(now())
  user        User         @relation("ExerciseAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  exercise    LangExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
}

model LangUserStats {
  id          String    @id @default(uuid())
  userId      String    @unique
  xp          Int       @default(0)
  level       Int       @default(1)
  streak      Int       @default(0)
  longestStreak Int     @default(0)
  lastStudied DateTime?
  wordsLearned Int      @default(0)
  exercisesDone Int     @default(0)
  user        User      @relation("LangUserStatsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp])
}

enum LangExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  MATCHING
  WORD_ORDER
  DICTATION
}

// ─── MATH MODULE ──────────────────────────────────────────────────────────────

enum MathSubject {
  ARITHMETIC
  ALGEBRA
  GEOMETRY
  TRIGONOMETRY
  CALCULUS
  STATISTICS
  NUMBER_THEORY
  COMBINATORICS
}

enum MathExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  TRUE_FALSE
  CALCULATION
  PROOF_STEP
}

model MathDocument {
  id            String   @id @default(uuid())
  originalName  String
  storedKey     String
  mimetype      String
  size          Int
  bucket        String
  status        String   @default("uploaded")
  extractedText String?  @db.Text
  grade         String?
  subject       String?
  errorMsg      String?
  createdBy     String
  creator       User     @relation("MathDocumentCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdBy])
  @@index([status])
}

model MathTopic {
  id          String         @id @default(uuid())
  title       String
  description String?
  subject     MathSubject    @default(ARITHMETIC)
  grade       Int            @default(1)
  level       String         @default("beginner")
  coverUrl    String?
  videoUrl    String?
  isPublic    Boolean        @default(true)
  createdBy   String
  courseId    String?
  concepts    MathConcept[]
  exercises   MathExercise[]
  creator     User           @relation("MathTopicCreator", fields: [createdBy], references: [id])
  course      Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([createdBy])
  @@index([subject])
  @@index([grade])
}

model MathConcept {
  id          String            @id @default(uuid())
  topicId     String
  name        String
  definition  String
  formula     String?
  example     String?
  solution    String?
  hints       String[]
  imageUrl    String?
  order       Int               @default(0)
  topic       MathTopic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  progresses  ConceptProgress[]
  createdAt   DateTime          @default(now())

  @@index([topicId])
}

model ConceptProgress {
  id          String      @id @default(uuid())
  userId      String
  conceptId   String
  interval    Int         @default(1)
  easeFactor  Float       @default(2.5)
  repetitions Int         @default(0)
  nextReview  DateTime    @default(now())
  lastReview  DateTime?
  isLearned   Boolean     @default(false)
  user        User        @relation("ConceptProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  concept     MathConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
  @@index([userId, nextReview])
  @@index([userId, isLearned])
}

model MathExercise {
  id          String           @id @default(uuid())
  title       String
  description String?
  type        MathExerciseType
  subject     MathSubject      @default(ARITHMETIC)
  grade       Int              @default(1)
  level       String           @default("beginner")
  timeLimit   Int?
  isPublic    Boolean          @default(true)
  createdBy   String
  topicId     String?
  courseId    String?
  questions   MathQuestion[]
  attempts    MathAttempt[]
  creator     User             @relation("MathExerciseCreator", fields: [createdBy], references: [id])
  topic       MathTopic?       @relation(fields: [topicId], references: [id], onDelete: SetNull)
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([createdBy])
  @@index([topicId])
  @@index([courseId])
}

model MathQuestion {
  id          String       @id @default(uuid())
  exerciseId  String
  content     String
  imageUrl    String?
  options     Json?
  answer      Json
  solution    String?
  hints       String[]
  difficulty  Int          @default(1)
  order       Int          @default(0)
  points      Int          @default(1)
  exercise    MathExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model MathAttempt {
  id          String       @id @default(uuid())
  userId      String
  exerciseId  String
  answers     Json
  score       Float
  timeTaken   Int?
  xpEarned    Int          @default(0)
  completedAt DateTime     @default(now())
  user        User         @relation("MathAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  exercise    MathExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
}

model MathUserStats {
  id              String    @id @default(uuid())
  userId          String    @unique
  xp              Int       @default(0)
  level           Int       @default(1)
  streak          Int       @default(0)
  longestStreak   Int       @default(0)
  lastStudied     DateTime?
  conceptsLearned Int       @default(0)
  exercisesDone   Int       @default(0)
  user            User      @relation("MathUserStatsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp])
}

// ─── TIẾNG VIỆT MODULE ────────────────────────────────────────────────────────

enum VietCategory {
  CHINH_TA        // Chính tả
  TU_VUNG         // Từ vựng
  NGU_PHAP        // Ngữ pháp
  THANH_NGU       // Thành ngữ
  TUC_NGU         // Tục ngữ
  VAN_HOC         // Văn học
  TAP_DOC         // Tập đọc / Đọc hiểu
  CA_DAO          // Ca dao
}

enum VietExerciseType {
  MULTIPLE_CHOICE   // Trắc nghiệm
  FILL_BLANK        // Điền từ / Điền vào chỗ trống
  SPELLING          // Chính tả (gõ đúng chữ)
  MATCHING          // Ghép cặp (từ ↔ nghĩa)
  WORD_ORDER        // Sắp xếp câu
  READING           // Đọc hiểu (passage + questions)
}

model VietDocument {
  id            String   @id @default(uuid())
  originalName  String
  storedKey     String
  mimetype      String
  size          Int
  bucket        String
  status        String   @default("uploaded")
  extractedText String?  @db.Text
  grade         String?
  category      String?
  errorMsg      String?
  createdBy     String
  creator       User     @relation("VietDocumentCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdBy])
  @@index([status])
}

model VietSet {
  id          String        @id @default(uuid())
  title       String
  description String?
  category    VietCategory  @default(TU_VUNG)
  grade       Int           @default(1)      // Lớp 1-12
  level       String        @default("co_ban")
  coverUrl    String?
  videoUrl    String?
  isPublic    Boolean       @default(true)
  createdBy   String
  courseId    String?
  items       VietItem[]
  exercises   VietExercise[]
  creator     User          @relation("VietSetCreator", fields: [createdBy], references: [id])
  course      Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([createdBy])
  @@index([category])
  @@index([grade])
}

model VietItem {
  id           String            @id @default(uuid())
  setId        String
  word         String            // Từ / thành ngữ / câu
  meaning      String            // Nghĩa / định nghĩa
  example      String?           // Ví dụ đặt câu
  note         String?           // Ghi chú thêm (nguồn gốc, cách dùng)
  imageUrl     String?
  audioUrl     String?
  order        Int               @default(0)
  set          VietSet           @relation(fields: [setId], references: [id], onDelete: Cascade)
  progresses   VietItemProgress[]
  createdAt    DateTime          @default(now())

  @@index([setId])
}

model VietItemProgress {
  id          String    @id @default(uuid())
  userId      String
  itemId      String
  interval    Int       @default(1)
  easeFactor  Float     @default(2.5)
  repetitions Int       @default(0)
  nextReview  DateTime  @default(now())
  lastReview  DateTime?
  isLearned   Boolean   @default(false)
  user        User      @relation("VietItemProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  item        VietItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, nextReview])
  @@index([userId, isLearned])
}

model VietExercise {
  id          String          @id @default(uuid())
  title       String
  description String?
  type        VietExerciseType
  category    VietCategory    @default(TU_VUNG)
  grade       Int             @default(1)
  level       String          @default("co_ban")
  passage     String?         // Đoạn văn cho bài đọc hiểu
  timeLimit   Int?
  isPublic    Boolean         @default(true)
  createdBy   String
  setId       String?
  courseId    String?
  questions   VietQuestion[]
  attempts    VietAttempt[]
  creator     User            @relation("VietExerciseCreator", fields: [createdBy], references: [id])
  set         VietSet?        @relation(fields: [setId], references: [id], onDelete: SetNull)
  course      Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdBy])
  @@index([setId])
  @@index([courseId])
}

model VietQuestion {
  id          String       @id @default(uuid())
  exerciseId  String
  content     String
  imageUrl    String?
  options     Json?
  answer      Json
  explanation String?
  order       Int          @default(0)
  points      Int          @default(1)
  exercise    VietExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model VietAttempt {
  id          String       @id @default(uuid())
  userId      String
  exerciseId  String
  answers     Json
  score       Float
  timeTaken   Int?
  xpEarned    Int          @default(0)
  completedAt DateTime     @default(now())
  user        User         @relation("VietAttemptUser", fields: [userId], references: [id], onDelete: Cascade)
  exercise    VietExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
}

model VietUserStats {
  id            String    @id @default(uuid())
  userId        String    @unique
  xp            Int       @default(0)
  level         Int       @default(1)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  lastStudied   DateTime?
  wordsLearned  Int       @default(0)
  exercisesDone Int       @default(0)
  user          User      @relation("VietUserStatsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp])
}

// ─── MODULE LINKS ─────────────────────────────────────────────────────────────

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  contentType String   // 'VOCAB_SET' | 'LANG_EXERCISE' | 'MATH_TOPIC' | 'MATH_EXERCISE' | 'VIET_SET' | 'VIET_EXERCISE'
  contentId   String
  addedAt     DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, contentType, contentId])
  @@index([courseId])
}

model LessonModule {
  id          String   @id @default(uuid())
  lessonId    String
  contentType String   // 'VOCAB_SET' | 'LANG_EXERCISE' | 'MATH_TOPIC' | 'MATH_EXERCISE' | 'VIET_SET' | 'VIET_EXERCISE' | 'MEDIA_FILE'
  contentId   String
  addedAt     DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, contentType, contentId])
  @@index([lessonId])
}

model ClassModule {
  id          String   @id @default(uuid())
  classId     String
  contentType String   // 'VOCAB_SET' | 'LANG_EXERCISE' | 'MATH_TOPIC' | 'MATH_EXERCISE' | 'VIET_SET' | 'VIET_EXERCISE'
  contentId   String
  addedAt     DateTime @default(now())
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, contentType, contentId])
  @@index([classId])
}

// ─── SITE SETTINGS ────────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── MEDIA LIBRARY ────────────────────────────────────────────────────────────

enum MediaType {
  VIDEO
  IMAGE
  DOCUMENT
}

enum MediaAccess {
  PUBLIC
  COURSE
  CLASS
  PRIVATE
}

model Media {
  id         String      @id @default(uuid())
  name       String
  fileKey    String
  fileSize   Int
  mimeType   String
  type       MediaType   @default(DOCUMENT)
  access     MediaAccess @default(PUBLIC)
  courseId   String?
  classId    String?
  uploadedBy String
  createdAt  DateTime    @default(now())
  uploader   User        @relation("MediaUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  course     Course?     @relation("MediaCourse", fields: [courseId], references: [id], onDelete: SetNull)
  class      Class?      @relation("MediaClass", fields: [classId], references: [id], onDelete: SetNull)

  @@index([uploadedBy])
  @@index([type])
  @@index([courseId])
  @@index([classId])
}

// ─── ANNOUNCEMENTS ────────────────────────────────────────────────────────────

enum AnnouncementTopic {
  SYSTEM
  COURSE
  CLASS
  EVENT
  GENERAL
}

model Announcement {
  id        String            @id @default(uuid())
  title     String
  content   String
  topic     AnnouncementTopic @default(GENERAL)
  authorId  String
  courseId  String?
  classId   String?
  isPinned  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  author    User              @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  course    Course?           @relation("AnnouncementCourse", fields: [courseId], references: [id], onDelete: SetNull)
  class     Class?            @relation("AnnouncementClass", fields: [classId], references: [id], onDelete: SetNull)
  reads     AnnouncementRead[]

  @@index([authorId])
  @@index([topic])
  @@index([courseId])
  @@index([classId])
  @@index([isPinned, createdAt])
}

model AnnouncementRead {
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation("AnnouncementReadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@index([userId])
}

// ─── FORUM ────────────────────────────────────────────────────────────────────

model ForumCategory {
  id          String      @id @default(uuid())
  name        String
  description String?
  icon        String?
  color       String?     @default("#6366f1")
  order       Int         @default(0)
  isHidden    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  posts       ForumPost[]

  @@index([order])
  @@index([isHidden])
}

enum ForumPostStatus {
  PENDING
  APPROVED
  REJECTED
}

model ForumPost {
  id         String          @id @default(uuid())
  title      String
  content    String
  categoryId String
  authorId   String
  isPinned   Boolean         @default(false)
  isClosed   Boolean         @default(false)
  isHidden   Boolean         @default(false)
  status     ForumPostStatus @default(APPROVED)
  views      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   ForumCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author     User            @relation("ForumPostAuthor", fields: [authorId], references: [id])
  replies    ForumReply[]
  likes      ForumLike[]     @relation("PostLike")

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isPinned, createdAt])
  @@index([status])
  @@index([isHidden])
}

model ForumReply {
  id        String      @id @default(uuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  post      ForumPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User        @relation("ForumReplyAuthor", fields: [authorId], references: [id])
  likes     ForumLike[] @relation("ReplyLike")

  @@index([postId])
  @@index([authorId])
}

model ForumLike {
  id        String      @id @default(uuid())
  userId    String
  postId    String?
  replyId   String?
  createdAt DateTime    @default(now())
  user      User        @relation("ForumLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  post      ForumPost?  @relation("PostLike", fields: [postId], references: [id], onDelete: Cascade)
  reply     ForumReply? @relation("ReplyLike", fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([postId])
  @@index([replyId])
}

// ─── QUIZ GAME ────────────────────────────────────────────────────────────────

enum QuizQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
}

model QuizSet {
  id          String         @id @default(uuid())
  title       String
  description String?
  topic       String
  authorId    String
  isPublic    Boolean        @default(true)
  timeLimit   Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User           @relation("QuizSetAuthor", fields: [authorId], references: [id])
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@index([authorId])
  @@index([topic])
  @@index([isPublic])
}

model QuizQuestion {
  id           String           @id @default(uuid())
  quizSetId    String
  question     String
  type         QuizQuestionType @default(MULTIPLE_CHOICE)
  options      String[]
  correctIndex Int?
  correctText  String?
  explanation  String?
  order        Int              @default(0)
  quizSet      QuizSet          @relation(fields: [quizSetId], references: [id], onDelete: Cascade)

  @@index([quizSetId])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  quizSetId String
  userId    String
  score     Int
  answers   Json
  timeTaken Int?
  createdAt DateTime @default(now())
  quizSet   QuizSet  @relation(fields: [quizSetId], references: [id], onDelete: Cascade)
  user      User     @relation("QuizAttemptUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizSetId])
  @@index([userId])
  @@index([quizSetId, score])
}
