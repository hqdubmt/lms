# ─── App ──────────────────────────────────────────────────────────────────────
# Domain hoặc IP của server (không có dấu / ở cuối)
# Ví dụ: http://123.456.789.0  hoặc  https://lms.yourdomain.com
FRONTEND_URL=http://your-server-ip-or-domain
APP_NAME=MasterLMS

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=lmsdb
POSTGRES_USER=lmsadmin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_DB=lmsdb
MONGO_USER=lmsadmin
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ACCESS_KEY=lmsadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_MIN_12CHARS
MINIO_BUCKET_VIDEOS=lms-videos
MINIO_BUCKET_ATTACHMENTS=lms-attachments
MINIO_BUCKET_AVATARS=lms-avatars

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_VERY_LONG_RANDOM_64CHAR_ACCESS_SECRET_HERE
JWT_REFRESH_SECRET=CHANGE_ME_VERY_LONG_RANDOM_64CHAR_REFRESH_SECRET_HERE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@yourdomain.com

# ─── AI (tuỳ chọn) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ─── Google OAuth (tuỳ chọn) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${FRONTEND_URL}/auth/google/callback

# ─── VNPay (tuỳ chọn) ────────────────────────────────────────────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
